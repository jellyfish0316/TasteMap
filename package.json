{
  "name": "tastemap",
  "version": "0.1.0",
  "private": true,
  "description": "TasteMap monorepo — web (frontend/), mobile (apps/mobile), shared packages, one backend.",
  "workspaces": [
    "frontend",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev -w tastemap-frontend",
    "web:build": "npm run build -w tastemap-frontend",
    "web:typecheck": "npm run typecheck -w tastemap-frontend",
    "mobile": "npm run start -w @tastemap/mobile",
    "mobile:ios": "npm run ios -w @tastemap/mobile",
    "mobile:typecheck": "npm run typecheck -w @tastemap/mobile"
  },
  "overrides": {
    "react": "18.3.1",
    "react-test-renderer": "18.3.1",
    "react-native-reanimated": "~3.16.1"
  }
}
