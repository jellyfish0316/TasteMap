# ---- App ----
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Auth ----
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- PostgreSQL / PostGIS ----
# docker-compose service name is `db`; use localhost when running the API on the host.
DATABASE_URL=postgresql+psycopg://tastemap:tastemap@localhost:5432/tastemap

# ---- Redis (task status, sessions, temp results, cache) ----
REDIS_URL=redis://localhost:6379/0

# ---- Celery (import / extraction / matching jobs) ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Dev/testing ----
# Run imports inline without a Celery worker/broker.
CELERY_TASK_ALWAYS_EAGER=true
# Route EVERY import to a built-in fake parser with canned (real) restaurant names —
# lets you test the full L1 flow with no scraping. Place matching is synthesized only
# if GOOGLE_PLACES_API_KEY is empty; set that key below to do REAL matching on the
# fake names (real google_place_id + coords). Turn OFF (false) for real parsers.
# NEVER enable in production.
FAKE_IMPORTS=true

# ---- External services (shared by all platform parsers) ----
# LLM used by the shared extraction helper (Extraction Service).
# Pick the backend: "anthropic" (default) or "openai". Fill the matching key below.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Places API (new) — every parser's output gets aligned to a google_place_id.
GOOGLE_PLACES_API_KEY=

# ---- Per-platform credentials (each platform owner fills what they need) ----
# Google Maps owner:
GOOGLE_MAPS_API_KEY=
# YouTube owner:
YOUTUBE_API_KEY=
# X / Twitter owner:
X_BEARER_TOKEN=
# Instagram owner (e.g. scraper service / oEmbed token):
INSTAGRAM_TOKEN=
# Threads owner:
THREADS_TOKEN=
